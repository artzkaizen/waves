{
  "name": "iot",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c cyan,magenta \"bun run dev:server\" \"bun run dev:client\"",
    "dev:server": "bun --watch server/index.ts",
    "dev:client": "vite --config client/vite.config.ts",
    "start": "bun server/index.ts",
    "build": "vite build --config client/vite.config.ts",
    "typecheck": "tsc -b",
    "lint": "oxlint",
    "test": "bun test",
    "db:generate": "drizzle-kit generate --config server/drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config server/drizzle.config.ts"
  },
  "dependencies": {
    "@fontsource-variable/figtree": "^5.2.10",
    "@hono/zod-openapi": "^1.5.0",
    "@scalar/hono-api-reference": "^0.11.9",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/react-query": "^5.101.2",
    "@tensorflow/tfjs-backend-wasm": "^4.22.0",
    "@tensorflow/tfjs-converter": "^4.22.0",
    "@tensorflow/tfjs-core": "^4.22.0",
    "@vladmandic/human": "^3.3.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.30",
    "jpeg-js": "^0.4.4",
    "lucide-react": "^1.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "drizzle-kit": "^0.31.10",
    "oxlint": "^1.69.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.0"
  }
}
