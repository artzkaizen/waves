# Copy to .env for local development. Never commit the real values.

# Shared secret the Raspberry Pi presents to push sensor data.
# Generate with:  openssl rand -hex 32
# The server REFUSES TO BOOT in production without this — see server/auth.ts.
WAVES_INGEST_TOKEN=dev-token-not-for-production

# Where the SQLite db and the recorded audio/video live.
# WAVES_DATA_DIR=./server/data

# PORT=8000
